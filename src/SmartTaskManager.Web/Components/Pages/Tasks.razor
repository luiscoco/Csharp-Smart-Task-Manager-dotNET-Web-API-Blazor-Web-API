@page "/tasks"
@using UiTaskStatus = SmartTaskManager.Web.Models.TaskStatus
@inject TasksApiClient TasksApiClient
@inject UserSession UserSession

<PageTitle>Tasks</PageTitle>

<div class="page-stack">
    <PageHeader
        Eyebrow="Tasks"
        Title="Task workspace"
        Description="Browse the selected user's tasks, apply one API-supported filter, and trigger simple lifecycle actions.">
        <Actions>
            <a class="button button--secondary" href="/tasks/create">Create task</a>
        </Actions>
    </PageHeader>

    @if (!UserSession.HasActiveUser)
    {
        <EmptyState
            Title="Task pages need an active user"
            Description="Select a user first so the web app can call the protected task endpoints with a bearer token.">
            <Actions>
                <a class="button" href="/users">Choose user</a>
            </Actions>
        </EmptyState>
    }
    else
    {
        @if (_errorMessage is not null)
        {
            <div class="callout callout--danger">
                <p>@_errorMessage</p>
            </div>
        }

        @if (_statusMessage is not null)
        {
            <div class="callout callout--success">
                <p>@_statusMessage</p>
            </div>
        }

        <section class="panel">
            <div class="panel__header">
                <div>
                    <p class="panel__eyebrow">Task list</p>
                    <h2 class="panel__title">@UserSession.CurrentUser!.UserName's tasks</h2>
                </div>

                <div class="toolbar">
                    <label class="toolbar__label" for="taskFilter">Filter</label>
                    <select id="taskFilter" class="field__input" @bind="_selectedFilter">
                        @foreach (TaskFilterOption option in Enum.GetValues<TaskFilterOption>())
                        {
                            <option value="@option">@GetFilterLabel(option)</option>
                        }
                    </select>
                    <button class="button button--ghost button--small" type="button" @onclick="LoadTasksAsync" disabled="@_isLoading">
                        Apply
                    </button>
                </div>
            </div>

            @if (_isLoading)
            {
                <div class="loading-panel">Loading tasks from the API...</div>
            }
            else if (_tasks.Count == 0)
            {
                <EmptyState
                    Title="No tasks matched the current filter"
                    Description="Create a task or clear the filter to see more work items.">
                    <Actions>
                        <a class="button" href="/tasks/create">Create task</a>
                    </Actions>
                </EmptyState>
            }
            else
            {
                <div class="task-list">
                    @foreach (TaskItem task in _tasks)
                    {
                        <article class="task-card">
                            <div class="task-card__header">
                                <div>
                                    <div class="task-card__title-row">
                                        <h3>@task.Title</h3>
                                        <StatusBadge Text="@task.Status.ToString()" Tone="@GetStatusTone(task.Status)" />
                                        <StatusBadge Text="@task.Priority.ToString()" Tone="@GetPriorityTone(task.Priority)" />
                                        @if (task.IsOverdue)
                                        {
                                            <StatusBadge Text="Overdue" Tone="danger" />
                                        }
                                    </div>

                                    <div class="task-card__meta">
                                        <span>Due @task.DueDate.ToLocalTime().ToString("dd MMM yyyy")</span>
                                        <span>@task.TaskType</span>
                                        <span>@task.CategoryName</span>
                                        <span>@task.HistoryCount history entries</span>
                                    </div>
                                </div>
                            </div>

                            <p class="task-card__description">@GetTaskDescription(task)</p>

                            <div class="task-card__actions">
                                <a class="button button--ghost button--small" href="@($"/tasks/{task.Id}")">Details</a>

                                @if (task.Status is not UiTaskStatus.Completed and not UiTaskStatus.Archived)
                                {
                                    <button
                                        class="button button--ghost button--small"
                                        type="button"
                                        @onclick="@(() => CompleteTaskAsync(task.Id))"
                                        disabled="@(_busyTaskId == task.Id)">
                                        Complete
                                    </button>
                                }

                                @if (task.Status != UiTaskStatus.Archived)
                                {
                                    <button
                                        class="button button--ghost button--small"
                                        type="button"
                                        @onclick="@(() => ArchiveTaskAsync(task.Id))"
                                        disabled="@(_busyTaskId == task.Id)">
                                        Archive
                                    </button>
                                }
                            </div>
                        </article>
                    }
                </div>
            }
        </section>
    }
</div>

@code {
    private bool _isLoading = true;
    private Guid? _busyTaskId;
    private string? _errorMessage;
    private string? _statusMessage;
    private TaskFilterOption _selectedFilter;
    private IReadOnlyCollection<TaskItem> _tasks = Array.Empty<TaskItem>();

    protected override async Task OnInitializedAsync()
    {
        await LoadTasksAsync();
    }

    private async Task LoadTasksAsync()
    {
        _errorMessage = null;
        _statusMessage = null;

        if (!UserSession.HasActiveUser || UserSession.CurrentUser is null || UserSession.BearerToken is null)
        {
            _tasks = Array.Empty<TaskItem>();
            _isLoading = false;
            return;
        }

        _isLoading = true;

        try
        {
            _tasks = await TasksApiClient.ListTasksAsync(
                UserSession.CurrentUser.Id,
                UserSession.BearerToken,
                BuildFilter());
        }
        catch (Exception exception)
        {
            _errorMessage = BuildErrorMessage(exception);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task CompleteTaskAsync(Guid taskId)
    {
        if (!TryGetSession(out Guid userId, out string? accessToken))
        {
            return;
        }

        _busyTaskId = taskId;
        _errorMessage = null;

        try
        {
            TaskItem task = await TasksApiClient.CompleteTaskAsync(userId, taskId, accessToken!);
            _statusMessage = $"Marked '{task.Title}' as completed.";
            await LoadTasksAsync();
        }
        catch (Exception exception)
        {
            _errorMessage = BuildErrorMessage(exception);
        }
        finally
        {
            _busyTaskId = null;
        }
    }

    private async Task ArchiveTaskAsync(Guid taskId)
    {
        if (!TryGetSession(out Guid userId, out string? accessToken))
        {
            return;
        }

        _busyTaskId = taskId;
        _errorMessage = null;

        try
        {
            TaskItem task = await TasksApiClient.ArchiveTaskAsync(userId, taskId, accessToken!);
            _statusMessage = $"Archived '{task.Title}'.";
            await LoadTasksAsync();
        }
        catch (Exception exception)
        {
            _errorMessage = BuildErrorMessage(exception);
        }
        finally
        {
            _busyTaskId = null;
        }
    }

    private bool TryGetSession(out Guid userId, out string? accessToken)
    {
        if (UserSession.CurrentUser is not null && UserSession.BearerToken is not null)
        {
            userId = UserSession.CurrentUser.Id;
            accessToken = UserSession.BearerToken;
            return true;
        }

        userId = Guid.Empty;
        accessToken = null;
        return false;
    }

    private TaskQueryFilter? BuildFilter()
    {
        return _selectedFilter switch
        {
            TaskFilterOption.Pending => new TaskQueryFilter(Status: UiTaskStatus.Pending),
            TaskFilterOption.InProgress => new TaskQueryFilter(Status: UiTaskStatus.InProgress),
            TaskFilterOption.Completed => new TaskQueryFilter(Status: UiTaskStatus.Completed),
            TaskFilterOption.Archived => new TaskQueryFilter(Status: UiTaskStatus.Archived),
            TaskFilterOption.HighPriority => new TaskQueryFilter(Priority: TaskPriority.High),
            TaskFilterOption.CriticalPriority => new TaskQueryFilter(Priority: TaskPriority.Critical),
            TaskFilterOption.Overdue => new TaskQueryFilter(Overdue: true),
            _ => null
        };
    }

    private static string GetTaskDescription(TaskItem task)
    {
        return string.IsNullOrWhiteSpace(task.Description)
            ? "No description was provided for this task."
            : task.Description;
    }

    private static string GetFilterLabel(TaskFilterOption option)
    {
        return option switch
        {
            TaskFilterOption.All => "All tasks",
            TaskFilterOption.Pending => "Pending",
            TaskFilterOption.InProgress => "In progress",
            TaskFilterOption.Completed => "Completed",
            TaskFilterOption.Archived => "Archived",
            TaskFilterOption.HighPriority => "High priority",
            TaskFilterOption.CriticalPriority => "Critical priority",
            TaskFilterOption.Overdue => "Overdue",
            _ => option.ToString()
        };
    }

    private static string GetPriorityTone(TaskPriority priority)
    {
        return priority switch
        {
            TaskPriority.Low => "neutral",
            TaskPriority.Medium => "warning",
            TaskPriority.High => "accent",
            TaskPriority.Critical => "danger",
            _ => "neutral"
        };
    }

    private static string GetStatusTone(UiTaskStatus status)
    {
        return status switch
        {
            UiTaskStatus.Pending => "neutral",
            UiTaskStatus.InProgress => "accent",
            UiTaskStatus.Completed => "success",
            UiTaskStatus.Archived => "warning",
            _ => "neutral"
        };
    }

    private static string BuildErrorMessage(Exception exception)
    {
        return exception switch
        {
            SmartTaskManagerApiException apiException => apiException.Message,
            HttpRequestException => "The web app could not reach the API. Start SmartTaskManager.Api and try again.",
            _ => "The task list could not be loaded."
        };
    }

    private enum TaskFilterOption
    {
        All,
        Pending,
        InProgress,
        Completed,
        Archived,
        HighPriority,
        CriticalPriority,
        Overdue
    }
}
