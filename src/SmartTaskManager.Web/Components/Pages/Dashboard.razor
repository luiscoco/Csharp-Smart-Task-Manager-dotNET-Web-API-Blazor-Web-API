@page "/"
@using UiTaskStatus = SmartTaskManager.Web.Models.TaskStatus
@implements IDisposable
@inject SmartTaskManagerApiClient ApiClient
@inject UserSession UserSession

<PageTitle>Dashboard</PageTitle>

<div class="page-stack">
    <PageHeader
        Eyebrow="Dashboard"
        Title="Portfolio dashboard"
        Description="Server-rendered overview of the selected user's workload, powered by the existing API.">
        <Actions>
            <a class="button button--secondary" href="/users">Switch user</a>
        </Actions>
    </PageHeader>

    @if (!UserSession.HasActiveUser)
    {
        <EmptyState
            Title="No workspace user selected"
            Description="Pick a user first so the web app can request a development token and load task data.">
            <Actions>
                <a class="button" href="/users">Open users</a>
            </Actions>
        </EmptyState>
    }
    else if (_isLoading)
    {
        <div class="loading-panel">Loading the dashboard for @UserSession.CurrentUser!.UserName...</div>
    }
    else if (_errorMessage is not null)
    {
        <div class="callout callout--danger">
            <p>@_errorMessage</p>
        </div>
    }
    else if (_summary is not null)
    {
        <section class="grid grid--metrics">
            <MetricCard Label="Total Tasks" Value="@_summary.TotalTasks.ToString()" Note="All tracked tasks for the active user." />
            <MetricCard Label="Pending" Value="@_summary.PendingTasks.ToString()" Note="Tasks waiting to be started." />
            <MetricCard Label="In Progress" Value="@_summary.InProgressTasks.ToString()" Note="Work already underway." />
            <MetricCard Label="Completed" Value="@_summary.CompletedTasks.ToString()" Note="Tasks already finished." />
            <MetricCard Label="Archived" Value="@_summary.ArchivedTasks.ToString()" Note="Preserved for history only." />
            <MetricCard Label="Overdue" Value="@_summary.OverdueTasks.ToString()" Note="Tasks that need attention now." />
        </section>

        <section class="panel">
            <div class="panel__header">
                <div>
                    <p class="panel__eyebrow">Recent tasks</p>
                    <h2 class="panel__title">Next work items for @UserSession.CurrentUser!.UserName</h2>
                </div>

                <a class="button button--ghost button--small" href="/tasks">Open task list</a>
            </div>

            @if (_recentTasks.Count == 0)
            {
                <EmptyState
                    Title="No tasks yet"
                    Description="Create the first task to see it appear on the dashboard.">
                    <Actions>
                        <a class="button" href="/tasks/create">Create task</a>
                    </Actions>
                </EmptyState>
            }
            else
            {
                <div class="task-list">
                    @foreach (TaskItem task in _recentTasks)
                    {
                        <article class="task-card">
                            <div class="task-card__header">
                                <div>
                                    <div class="task-card__title-row">
                                        <h3>@task.Title</h3>
                                        <StatusBadge Text="@task.Status.ToString()" Tone="@GetStatusTone(task.Status)" />
                                        <StatusBadge Text="@task.Priority.ToString()" Tone="@GetPriorityTone(task.Priority)" />
                                    </div>

                                    <div class="task-card__meta">
                                        <span>Due @task.DueDate.ToLocalTime().ToString("dd MMM yyyy")</span>
                                        <span>@task.TaskType</span>
                                        <span>@task.CategoryName</span>
                                    </div>
                                </div>

                                @if (task.IsOverdue)
                                {
                                    <StatusBadge Text="Overdue" Tone="danger" />
                                }
                            </div>

                            <p class="task-card__description">@GetTaskDescription(task)</p>

                            <div class="task-card__actions">
                                <a class="button button--ghost button--small" href="@($"/tasks/{task.Id}")">View details</a>
                            </div>
                        </article>
                    }
                </div>
            }
        </section>
    }
</div>

@code {
    private bool _isLoading = true;
    private string? _errorMessage;
    private TaskDashboardSummary? _summary;
    private IReadOnlyCollection<TaskItem> _recentTasks = Array.Empty<TaskItem>();

    protected override async Task OnInitializedAsync()
    {
        UserSession.Changed += HandleSessionChanged;
        await LoadAsync();
    }

    public void Dispose()
    {
        UserSession.Changed -= HandleSessionChanged;
    }

    private void HandleSessionChanged()
    {
        _ = InvokeAsync(LoadAsync);
    }

    private async Task LoadAsync()
    {
        _errorMessage = null;
        _summary = null;
        _recentTasks = Array.Empty<TaskItem>();

        if (!UserSession.HasActiveUser || UserSession.CurrentUser is null || UserSession.BearerToken is null)
        {
            _isLoading = false;
            await InvokeAsync(StateHasChanged);
            return;
        }

        _isLoading = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            Task<TaskDashboardSummary> dashboardTask = ApiClient.GetDashboardAsync(
                UserSession.CurrentUser.Id,
                UserSession.BearerToken);

            Task<IReadOnlyCollection<TaskItem>> tasksTask = ApiClient.GetTasksAsync(
                UserSession.CurrentUser.Id,
                UserSession.BearerToken);

            await Task.WhenAll(dashboardTask, tasksTask);

            _summary = dashboardTask.Result;
            _recentTasks = tasksTask.Result
                .OrderBy(task => task.DueDate)
                .Take(5)
                .ToList();
        }
        catch (Exception exception)
        {
            _errorMessage = BuildErrorMessage(exception);
        }
        finally
        {
            _isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private static string GetTaskDescription(TaskItem task)
    {
        return string.IsNullOrWhiteSpace(task.Description)
            ? "No description was provided for this task."
            : task.Description;
    }

    private static string GetPriorityTone(TaskPriority priority)
    {
        return priority switch
        {
            TaskPriority.Low => "neutral",
            TaskPriority.Medium => "warning",
            TaskPriority.High => "accent",
            TaskPriority.Critical => "danger",
            _ => "neutral"
        };
    }

    private static string GetStatusTone(UiTaskStatus status)
    {
        return status switch
        {
            UiTaskStatus.Pending => "neutral",
            UiTaskStatus.InProgress => "accent",
            UiTaskStatus.Completed => "success",
            UiTaskStatus.Archived => "warning",
            _ => "neutral"
        };
    }

    private static string BuildErrorMessage(Exception exception)
    {
        return exception switch
        {
            SmartTaskManagerApiException apiException => apiException.Message,
            HttpRequestException => "The web app could not reach the API. Start SmartTaskManager.Api and try again.",
            _ => "The dashboard could not be loaded."
        };
    }
}
