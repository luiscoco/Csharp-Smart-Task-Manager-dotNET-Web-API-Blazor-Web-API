{
  "ConnectionStrings": {
    "SmartTaskManager": "Server=localhost;Database=SmartTaskManagerDb;Integrated Security=True;TrustServerCertificate=True;Encrypt=False;MultipleActiveResultSets=True"
  },
  "Database": {
    "EnableEfLogging": false,
    "EnableDetailedErrors": false,
    "EnableSensitiveDataLogging": false
  },
  "Jwt": {
    "Issuer": "SmartTaskManager.Api",
    "Audience": "SmartTaskManager.Swagger",
    "SigningKey": "SmartTaskManager-Development-Signing-Key-2026",
    "TokenLifetimeMinutes": 60
  },
  "Seeding": {
    "EnableSampleData": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
